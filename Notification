<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notification Button</title>
    <style>
        body {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            background-color: #f0f2f5;
            font-family: Arial, sans-serif;
        }
        button {
            padding: 15px 30px;
            font-size: 18px;
            cursor: pointer;
            background-color: #007bff;
            color: white;
            border: none;
            border-radius: 5px;
            box-shadow: 0 4px 6px rgba(0,0,0,0,1);
            transition: background 0.2s;
        }
        button:hover {
            background-color: #0056b3;
        }
    </style>
</head>
<body>

    <button onclick="showNotification()">Notification Dikhao!</button>

    <script>
        function showNotification() {
            // 1. Check karna ki browser notification support karta hai ya nahi
            if (!("Notification" in window)) {
                alert("Aapka browser notifications support nahi karta.");
                return;
            }

            // 2. Check karna ki permission mili hui hai ya nahi
            if (Notification.permission === "granted") {
                // Agar permission pehle se hai, to notification dikhao
                new Notification("Hello Bhai!", {
                    body: "Yeh aapka notification hai! 😎",
                    icon: "https://via.placeholder.com/100" // Aap yahan apna icon lagakar change kar sakte ho
                });
            } 
            // 3. Agar permission 'default' hai (na haan, na naa), to permission mango
            else if (Notification.permission !== "denied") {
                Notification.requestPermission().then(permission => {
                    if (permission === "granted") {
                        new Notification("Shukriya!", {
                            body: "Ab aapko notifications milenge."
                        });
                    }
                });
            }
            // Agar user ne block kar rakha hai
            else {
                alert("Aapne notifications block kiye hue hain. Browser settings se allow kijiye.");
            }
        }
    </script>

</body>
</html>
